          ]
        }
      },
      "id": "set-safe-id",
      "name": "Activar Modo Seguro",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [860, 200]
    },
    {
      "parameters": {
        "values": {
          "boolean": [
            {
              "name": "modo_seguro",
              "value": false
            }
          ]
        }
      },
      "id": "set-no-safe-id",
      "name": "Modo Estándar",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [860, 400]
    },
    {
      "parameters": {
        "model": "gpt-4-turbo",
        "prompt": "=Actúa como un Entrenador Senior y Nutricionista.\n\nCONTEXTO DEL USUARIO:\n- Peso actual: {{ $node[\"Preparar Datos\"].json[\"weight\"] }} kg\n- Preferencia Alimentaria: {{ $node[\"Preparar Datos\"].json[\"diet\"] }}\n- Lesiones reportadas: {{ $node[\"Webhook Flutter\"].json[\"body\"][\"injuries\"].join(', ') }}\n- Modo de Seguridad: {{ $node[\"Activar Modo Seguro\"].json[\"modo_seguro\"] || $node[\"Modo Estándar\"].json[\"modo_seguro\"] }}\n\nTAREA:\n1. Crea una rutina de entrenamiento de 3 días.\n2. Diseña un plan de comidas diario basado en su dieta ({{ $node[\"Preparar Datos\"].json[\"diet\"] }}).\n3. REGLA CRÍTICA: Si el Modo de Seguridad es true, excluye ejercicios que pongan presión en: {{ $node[\"Webhook Flutter\"].json[\"body\"][\"injuries\"].join(', ') }}.\n\nFormato: Responde en JSON estructurado con secciones para 'entrenamiento' y 'nutricion'.",
        "options": {}
      },
      "id": "ai-id",
      "name": "IA: Generador de Plan",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "table": "fitness_plans",
