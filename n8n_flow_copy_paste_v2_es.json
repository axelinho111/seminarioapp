              "fieldValue": "completed"
            }
          ]
        }
      },
      "id": "supabase-update-id",
      "name": "Supabase: Guardar Plan",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1350, 300]
    }
